    "module_name": "ascii_smuggling",
    "class_name": "AsciiSmuggling",
    "category": "Homoglyph/Obfuscation",
    "file_exists": true,
    "file_size": 3594,
    "source_lines": 89,
    "uses_mapping": true,
    "has_params": true,
    "docstring": "Use Unicode tags to smuggle ASCII characters.\n        For tag char smuggling to work, it must be appended to an emoji, per the Unicode spec.\n        https://unicode.org/reports/tr51/\n\n        Args:\n            payload (str): The payload we wish to hide.\n            desired_emoji (str): Must be an emoji per unicode spec. Defaults to 😈\n\n        Returns:\n            desired_emoji + encoded payload (str): Payload encoded in unicode tags attached to the emoji."
  },
